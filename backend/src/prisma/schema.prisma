generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  Admin
  WarehouseManager
  Operator
  Viewer
}

enum WarehouseStatus {
  Active
  Inactive
  Maintenance
}

enum OrderType {
  Inbound
  Outbound
  Transfer
  InventoryCheck
}

enum OrderStatus {
  Draft
  Submitted
  Processing
  Completed
  Cancelled
}

enum OperationType {
  Inbound
  Outbound
  Adjust
  Transfer
}

model Role {
  id          String   @id @default(cuid())
  name        UserRole @unique
  displayName String
  users       User[]
  createdAt   DateTime @default(now())
}

model User {
  id           String         @id @default(cuid())
  username     String         @unique
  displayName  String
  roleId       String
  role         Role           @relation(fields: [roleId], references: [id])
  managedWarehouses Warehouse[]
  createdOrders StockOrder[]  @relation("CreatedOrders")
  approvedOrders StockOrder[] @relation("ApprovedOrders")
  operationLogs OperationLog[]
  createdAt     DateTime      @default(now())
}

model Warehouse {
  id           String          @id @default(cuid())
  name         String
  code         String          @unique
  address      String
  area         Decimal         @db.Decimal(10, 2)
  managerId    String?
  manager      User?           @relation(fields: [managerId], references: [id])
  status       WarehouseStatus @default(Active)
  contactPhone String
  shelves      Shelf[]
  stockRecords StockRecord[]
  sourceOrders StockOrder[]    @relation("SourceWarehouse")
  targetOrders StockOrder[]    @relation("TargetWarehouse")
  operationLogs OperationLog[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model Shelf {
  id           String        @id @default(cuid())
  warehouseId  String
  warehouse    Warehouse     @relation(fields: [warehouseId], references: [id])
  shelfCode    String
  levels       Int
  columns      Int
  capacity     Int
  stockRecords StockRecord[]
  orderItems   StockOrderItem[]
  createdAt    DateTime      @default(now())

  @@unique([warehouseId, shelfCode])
}

model Category {
  id       String     @id @default(cuid())
  name     String
  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  sort     Int        @default(0)
  icon     String?
  products Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id            String        @id @default(cuid())
  name          String
  sku           String        @unique
  categoryId    String
  category      Category      @relation(fields: [categoryId], references: [id])
  spec          String
  unit          String
  weight        Decimal       @db.Decimal(10, 3)
  volume        Decimal       @db.Decimal(10, 3)
  barcode       String        @unique
  minStock      Int
  maxStock      Int
  shelfLifeDays Int?
  imageUrl      String?
  price         Decimal       @default(0) @db.Decimal(10, 2)
  stockRecords  StockRecord[]
  orderItems    StockOrderItem[]
  operationLogs OperationLog[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model StockRecord {
  id                 String        @id @default(cuid())
  productId          String
  product            Product       @relation(fields: [productId], references: [id])
  warehouseId        String
  warehouse          Warehouse     @relation(fields: [warehouseId], references: [id])
  shelfId            String?
  shelf              Shelf?        @relation(fields: [shelfId], references: [id])
  batchNo            String
  quantity           Int
  inboundDate        DateTime
  expiryDate         DateTime?
  lastOperationType  OperationType @default(Inbound)
  lastOperationAt    DateTime      @default(now())
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([productId, warehouseId, batchNo])
}

model StockOrder {
  id                 String          @id @default(cuid())
  orderNo            String          @unique
  type               OrderType
  sourceWarehouseId  String?
  sourceWarehouse    Warehouse?      @relation("SourceWarehouse", fields: [sourceWarehouseId], references: [id])
  targetWarehouseId  String?
  targetWarehouse    Warehouse?      @relation("TargetWarehouse", fields: [targetWarehouseId], references: [id])
  status             OrderStatus     @default(Draft)
  createdById        String
  createdBy          User            @relation("CreatedOrders", fields: [createdById], references: [id])
  approvedById       String?
  approvedBy         User?           @relation("ApprovedOrders", fields: [approvedById], references: [id])
  remark             String?
  items              StockOrderItem[]
  operationLogs      OperationLog[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model StockOrderItem {
  id             String      @id @default(cuid())
  orderId        String
  order          StockOrder  @relation(fields: [orderId], references: [id])
  productId      String
  product        Product     @relation(fields: [productId], references: [id])
  shelfId        String?
  shelf          Shelf?      @relation(fields: [shelfId], references: [id])
  quantity       Int
  actualQuantity Int?
  createdAt      DateTime    @default(now())
}

model OperationLog {
  id            String         @id @default(cuid())
  operationType OperationType
  entityType    String
  entityId      String?
  warehouseId   String?
  warehouse     Warehouse?     @relation(fields: [warehouseId], references: [id])
  productId     String?
  product       Product?       @relation(fields: [productId], references: [id])
  orderId       String?
  order         StockOrder?    @relation(fields: [orderId], references: [id])
  operatorId    String?
  operator      User?          @relation(fields: [operatorId], references: [id])
  beforeData    Json?
  afterData     Json?
  remark        String?
  createdAt     DateTime       @default(now())
}
