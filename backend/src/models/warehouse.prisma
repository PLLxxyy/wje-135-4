model Warehouse {
  id           String          @id @default(cuid())
  name         String
  code         String          @unique
  address      String
  area         Decimal         @db.Decimal(10, 2)
  managerId    String?
  status       WarehouseStatus @default(Active)
  contactPhone String
}

model Shelf {
  id          String @id @default(cuid())
  warehouseId String
  shelfCode   String
  levels      Int
  columns     Int
  capacity    Int
}
